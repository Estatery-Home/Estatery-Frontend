# Copy this file to .env (same folder as manage.py), fill in, restart runserver.

# --- Gmail SMTP ---
# 1) Google Account → Security → enable 2-Step Verification
# 2) Security → App passwords → create "Mail" → copy the 16-char password (spaces optional)
# 3) EMAIL_HOST_USER / DEFAULT_FROM_EMAIL = your full Gmail address

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_HOST_USER=yourname@gmail.com
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=yourname@gmail.com
